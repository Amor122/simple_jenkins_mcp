# Jenkins MCP Server 配置

# ============ Jenkins 连接配置 ============
# Jenkins 服务器地址 (必需)
JENKINS_URL=http://localhost:8080

# Jenkins 用户名 (必需)
JENKINS_USERNAME=admin

# Jenkins 密码或 API Token (必需)
# 推荐使用 API Token 而非密码
# 获取方式: Jenkins -> 用户 -> 设置 -> API Token
JENKINS_PASSWORD=your_api_token_here

# 请求超时时间(秒)
JENKINS_TIMEOUT=30

# 是否验证SSL证书 (true/false)
# 生产环境建议设为 true
JENKINS_VERIFY_SSL=true

# 只读模式 (true/false)
# 设为 true 时，所有写操作(创建/删除/修改)将被禁止
JENKINS_READ_ONLY=false

# ============ MCP 服务器配置 ============
# 传输方式: stdio, sse, streamable-http
# - stdio: 用于本地stdin/stdout通信
# - streamable-http: 用于HTTP远程访问
MCP_TRANSPORT=streamable-http

# HTTP监听地址
MCP_HOST=0.0.0.0

# HTTP监听端口
MCP_PORT=8000

# ============ 配置文件路径 ============
# 指定 .env 配置文件路径
JENKINS_CONFIG_PATH=.env